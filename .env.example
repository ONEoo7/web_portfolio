# ──────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in your values
# ──────────────────────────────────────────────────────────────────────────────

# Your DDNS hostname (e.g. stefan.duckdns.org)
DOMAIN=YOUR_DDNS_DOMAIN.example.com

# Email for Let's Encrypt expiry notices
CERTBOT_EMAIL=your@email.com

# ──────────────────────────────────────────────────────────────────────────────
# LiteLLM proxy (running externally — not in this compose stack)
# ──────────────────────────────────────────────────────────────────────────────
# URL of the externally-managed LiteLLM proxy reachable from the api container.
LITELLM_URL=http://host.docker.internal:4000

# Master key used by the api service to authenticate against LiteLLM.
LITELLM_MASTER_KEY=sk-replace-me-with-a-strong-random-key

# ──────────────────────────────────────────────────────────────────────────────
# Model aliases — must match `model_name` entries in your LiteLLM proxy config.
# The api sends these strings to LiteLLM; LiteLLM maps them to real upstreams.
# ──────────────────────────────────────────────────────────────────────────────
COPILOT_MODEL=chat
EMBEDDING_MODEL=embeddings

# ──────────────────────────────────────────────────────────────────────────────
# Site identity — used by the api when generating the resume PDFs.
# ──────────────────────────────────────────────────────────────────────────────
# Public hostname shown in the resume header (no scheme needed).
SITE_URL=YOUR_DDNS_DOMAIN.example.com
# Full name used on the resume / CV.
RESUME_NAME=Your Name

# ──────────────────────────────────────────────────────────────────────────────
# Synology NAS deployment (docker-compose.nas.yml) — see docs/DEPLOY-SYNOLOGY.md
# ──────────────────────────────────────────────────────────────────────────────
# On the NAS, point LITELLM_URL at the Windows PC's LAN IP instead of
# host.docker.internal, e.g.:
#   LITELLM_URL=http://192.168.1.50:4000
# DSM's reverse proxy handles TLS, so DOMAIN/CERTBOT_EMAIL above are unused there.
