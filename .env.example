# ──────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in your values
# ──────────────────────────────────────────────────────────────────────────────

# Your DDNS hostname (e.g. stefan.duckdns.org)
DOMAIN=YOUR_DDNS_DOMAIN.example.com

# Email for Let's Encrypt expiry notices
CERTBOT_EMAIL=your@email.com

# ──────────────────────────────────────────────────────────────────────────────
# LiteLLM proxy (running externally — not in this compose stack)
# ──────────────────────────────────────────────────────────────────────────────
# URL of the externally-managed LiteLLM proxy reachable from the api container.
LITELLM_URL=http://host.docker.internal:4000

# Master key used by the api service to authenticate against LiteLLM.
LITELLM_MASTER_KEY=sk-replace-me-with-a-strong-random-key
